# ===========================================
# Halo Patient Concierge - Environment Config
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Session ---
# REQUIRED: Generate a strong random secret (e.g. openssl rand -hex 32)
SESSION_SECRET=

# --- Google OAuth 2.0 ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Gemini AI ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Deepgram (optional) ---
# Medical transcription. Falls back to Gemini if not set.
# Get your key at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# --- URLs ---
# Frontend URL (used for CORS and OAuth redirect)
CLIENT_URL=http://localhost:5173
# Production URL (used for OAuth redirect in production)
# PRODUCTION_URL=https://your-domain.com

# --- Halo Notegen API (optional overrides) ---
# HALO_API_BASE_URL=https://halo-functions-75316778879.africa-south1.run.app
# HALO_USER_ID=05588e47-5e6b-4a5e-85b8-9733a12b4868

# --- Template request email (optional) ---
# When set, "Request new template" in Settings sends an email to ADMIN_EMAIL.
# ADMIN_EMAIL=admin@halo.africa
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
