# ===========================================
# Halo Patient Concierge - Environment Config
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Session ---
# REQUIRED: Generate a strong random secret (e.g. openssl rand -hex 32)
SESSION_SECRET=

# --- Google OAuth 2.0 ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Scopes used by HALO include:
# - https://www.googleapis.com/auth/drive
# - https://www.googleapis.com/auth/calendar.events (read/write bookings)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Gemini AI ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Deepgram (optional) ---
# Medical transcription. Falls back to Gemini if not set.
# Get your key at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# --- URLs ---
# Frontend URL (used for CORS and OAuth redirect)
CLIENT_URL=http://localhost:5173
# Production URL (used for OAuth redirect in production)
# PRODUCTION_URL=https://your-domain.com

# --- Feature flags (frontend) ---
# Set to 'false' to temporarily disable the expanded calendar UI.
VITE_ENABLE_EXPANDED_CALENDAR=true

# --- Halo note generation (optional overrides) ---
# HALO_API_BASE_URL=https://halo-functions-75316778879.africa-south1.run.app
# HALO_USER_ID=default-user-uuid
# When set in development, templates and generate_note use this user so you can test a different template set.
# HALO_TEST_USER_ID=another-user-uuid

# When the signed-in user's email matches HALO_OVERRIDE_EMAIL, use this user ID and (optionally) only these template IDs.
# HALO_OVERRIDE_EMAIL=you@example.com
# HALO_OVERRIDE_USER_ID=686acfac-5b85-47b4-b4a6-c9e64e8d0736
# HALO_OVERRIDE_TEMPLATE_IDS=multi_note,op_note,scribe

# Assistant "Generate DOCX" merges into this Drive file (.dotx/.docx). Template needs one tag: {{body}} (patient lines are prepended server-side).
# Set to empty to skip Drive and use HALO_LETTERHEAD_LOCAL_PATH only.
# HALO_LETTERHEAD_DRIVE_FILE_ID=
# Optional: absolute path to a .docx/.dotx file, or a folder containing one (Letter Head.dotx preferred).
# HALO_LETTERHEAD_LOCAL_PATH=

# --- Google Calendar bookings (optional but recommended) ---
# Calendar used to pull today’s bookings for the sidebar calendar.
# If not set, the primary calendar is used.
# BOOKINGS_CALENDAR_ID=your-bookings-calendar-id@group.calendar.google.com

# --- Template request email (optional) ---
# When set, "Request new template" in Settings sends an email to ADMIN_EMAIL.
# ADMIN_EMAIL=admin@halo.africa
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
